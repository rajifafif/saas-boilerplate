{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": false,
    "skipLibCheck": true
  },
  "vueCompilerOptions": {
    "strictTemplates": false,
    "skipTemplateCodegen": true
  },
  "exclude": [
    "node_modules",
    ".output",
    "views/**",
    "components/users/**",
    "components/profile/**",
    "components/dialogs/TwoFactorAuthDialog.vue",
    "layouts/components/UserProfile.vue",
    "@core/libs/chartjs/**",
    "@core/components/AppCardCode.vue",
    "@core/components/app-form-elements/**",
    "@layouts/components/**",
    "@layouts/plugins/casl.ts",
    "@layouts/utils.ts",
    "plugins/iconify/**",
    "plugins/layouts.ts",
    "plugins/vuetify/**",
    "pages/manage/roles/**",
    "pages/manage/users/**"
  ]
}
