{
  "name": "saas-boilerplate-frontend",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run build:env:local && nuxt dev",
    "dev:production": "bun run build:env:prod && nuxt dev",
    "build": "bun run build:env:prod && bun run build:nuget",
    "build:nuget": "node --max-old-space-size=8192 node_modules/nuxt/bin/nuxt.mjs build",
    "build:env:local": "cp .env.local .env",
    "build:env:prod": "cp .env.production .env",
    "lint": "eslint . --fix",
    "build:icons": "bun plugins/iconify/build-icons.ts",
    "postinstall": "nuxt prepare && bun run build:icons",
    "generate": "bun run build:env:local && nuxt generate && cp .htaccess .output/public/",
    "generate:production": "bun run build:env:prod && nuxt generate && cp .htaccess .output/public/",
    "start": "nuxt start",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "cleanup": "rm -rf node_modules .nuxt .output dist"
  },
  "dependencies": {
    "@capacitor/core": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@casl/ability": "^6.7.5",
    "@casl/vue": "^2.2.2",
    "@date-io/dayjs": "^3.2.0",
    "@floating-ui/dom": "^1.7.4",
    "@formkit/drag-and-drop": "^0.1.6",
    "@nuxtjs/device": "^3.2.4",
    "@nuxtjs/i18n": "^9.5.6",
    "@sidebase/nuxt-auth": "^0.10.1",
    "@tiptap/extension-highlight": "^2.27.1",
    "@tiptap/extension-image": "^2.27.1",
    "@tiptap/extension-link": "^2.27.1",
    "@tiptap/extension-text-align": "^2.27.1",
    "@tiptap/pm": "^2.27.1",
    "@tiptap/starter-kit": "^2.27.1",
    "@tiptap/vue-3": "^2.27.1",
    "@vueuse/core": "^10.11.1",
    "@vueuse/math": "^10.11.1",
    "apexcharts": "^4.7.0",
    "dayjs": "^1.11.19",
    "destr": "^2.0.5",
    "firebase": "^11.10.0",
    "jwt-decode": "^4.0.0",
    "mapbox-gl": "^3.17.0",
    "next-auth": "^4.24.13",
    "nuxt": "^4.2.2",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "swiper": "^11.2.10",
    "vue-flatpickr-component": "^11.0.5",
    "vue3-apexcharts": "^1.10.0",
    "vue3-perfect-scrollbar": "^2.0.0",
    "vuetify": "^3.11.5",
    "webfontloader": "^1.6.28"
  },
  "devDependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@fullcalendar/vue3": "^6.1.20",
    "@iconify-json/fa": "^1.2.2",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/tabler": "^1.2.25",
    "@iconify/tools": "^4.2.0",
    "@iconify/utils": "^2.3.0",
    "@iconify/vue": "^4.3.0",
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/typescript": "^2.8.1",
    "@pinia/nuxt": "^0.9.0",
    "@tiptap/extension-character-count": "^2.27.1",
    "@tiptap/extension-placeholder": "^2.27.1",
    "@tiptap/extension-subscript": "^2.27.1",
    "@tiptap/extension-superscript": "^2.27.1",
    "@tiptap/extension-underline": "^2.27.1",
    "@types/node": "22",
    "@vueuse/nuxt": "^12.8.2",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^9.33.0",
    "sass": "^1.97.1",
    "shiki": "^4.2.0",
    "stylelint": "^16.26.1",
    "tsx": "^4.21.0",
    "type-fest": "4",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vite-plugin-vuetify": "^2.1.2",
    "vite-svg-loader": "^5.1.0",
    "vue-shepherd": "^3.0.0"
  }
}
